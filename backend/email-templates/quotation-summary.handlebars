<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #f8faff;
      font-family: Arial, sans-serif;
      color: #333;
    }

    .email-container {
      max-width: 420px;
      margin: 20px auto;
      background-color: #fff;
      border-radius: 12px;
      border: 1px solid #e0e7ff;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .header {
      background-color: #2563eb;
      color: white;
      padding: 20px;
      text-align: center;
    }

    .header img {
      width: 70px;
      background-color: white;
      padding: 6px;
      border-radius: 8px;
      margin-bottom: 8px;
    }

    .header h1 {
      margin: 0;
      font-size: 20px;
    }

    .content {
      padding: 20px;
      font-size: 15px;
      line-height: 1.5;
    }

    /* Full Width PDF Attachment Box */
    .pdf-attachment {
      display: block;
      width: 100%;
      text-decoration: none;
      background-color: #fff5f5;
      border: 2px solid #d32f2f;
      border-radius: 8px;
      padding: 15px;
      margin-top: 20px;
      color: #d32f2f;
      font-weight: bold;
      font-size: 14px;
      box-sizing: border-box;
    }

    .pdf-attachment:hover {
      background-color: #fdecea;
      border-color: #b71c1c;
      color: #b71c1c;
    }

    .pdf-attachment span {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .footer {
      background-color: #f1f5ff;
      padding: 12px;
      font-size: 12px;
      color: #6b7280;
      text-align: center;
    }
  </style>
</head>

<body>
  <div class="email-container">
    <!-- Header -->
    <div class="header">
      <img src="https://erp.hirinternational.com/assets/hir-logo-DivPsUXd.png" alt="Hir International Logo" />
      <h1>Hir International</h1>
    </div>

    <!-- Message -->
    <div class="content">
      <p>
        Hello <strong>{{name}}</strong>, thank you for your interest in Hir International’s travel services. 
        Please find your detailed quotation in the PDF linked below. 
        We look forward to assisting you in planning your journey.
      </p>

      <!-- PDF Attachment Box -->
      <a href="{{quotationUrl}}" class="pdf-attachment" target="_blank">
        <span>📄 &nbsp; Quotation.pdf</span>
      </a>
    </div>

    <!-- Footer -->
    <div class="footer">
      © <span id="year">2025</span> Hir International — Rajkot, Gujarat, India
    </div>
  </div>
</body>

</html>
